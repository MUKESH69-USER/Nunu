def scc4(ccx):
    try:
        cc_clean = re.sub(r'[^\d]', '', str(ccx))
        if len(cc_clean) < 15 or len(cc_clean) > 16:
            return {'status': False, 'formatted': ccx, 'bin': cc_clean[:6] if len(cc_clean) >= 6 else '', 'error': 'Invalid card length'}
        def luhn_check(card_num):
            digits = [int(d) for d in card_num]
            odd_digits = digits[-1::-2]
            even_digits = digits[-2::-2]
            total = sum(odd_digits)
            for d in even_digits:
                total += sum(divmod(d * 2, 10))
            return total % 10 == 0
        if not luhn_check(cc_clean):
            return {'status': False, 'formatted': ' '.join([cc_clean[i:i+4] for i in range(0, len(cc_clean), 4)]), 'bin': cc_clean[:6], 'error': 'Luhn check failed'}
        formatted_cc = ' '.join([cc_clean[i:i+4] for i in range(0, len(cc_clean), 4)])
        bin_number = cc_clean[:6]
        card_type = "Unknown"
        first_digit = cc_clean[0]
        if first_digit == '4': card_type = "Visa"
        elif first_digit == '5': card_type = "MasterCard"
        elif first_digit == '3': card_type = "Amex"
        elif first_digit == '6': card_type = "Discover"
        return {'status': True, 'formatted': formatted_cc, 'bin': bin_number, 'type': card_type, 'error': None}
    except Exception as e:
        return {'status': False, 'formatted': str(ccx), 'bin': '', 'error': str(e)}

def sh(card):
    result = scc4(card)
    if result['status'] and result['formatted']:
        return result['formatted']
    return card

def find_between(s, start, end):
    try:
        if start in s and end in s:
            return (s.split(start))[1].split(end)[0]
        return ""
    except:
        return ""

def extract_from_json(text, key):
    pattern = r'"{0}"\s*:\s*"([^"]+)"'.format(key)
    match = re.search(pattern, text)
    return match.group(1) if match else None

def get_redirect_url(html):
    match = re.search(r"window\.location\.href\s*=\s*'([^']+)'", html)
    if match:
        return match.group(1)
    return None

