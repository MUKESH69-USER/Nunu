            session_response = await session.post(endpoint, headers=headers, json=json_data)
            if session_response.status_code == 200:
                session_id = session_response.json().get('id')
                print(f"✅ Payment session created: {session_id[:20]}...")
                return session_id
            else:
                print(f"Payment session failed: HTTP {session_response.status_code}")
        except Exception as e:
            print(f"Payment session exception: {e}")
            continue
    return None

